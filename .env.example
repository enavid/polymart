# Copy to .env and adjust. Never commit the real .env.

# --- Django -----------------------------------------------------------------
DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_SECRET_KEY=insecure-dev-key-change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_LOG_LEVEL=INFO
DJANGO_JSON_LOGS=false

# --- Database ---------------------------------------------------------------
POSTGRES_USER=polymart
POSTGRES_PASSWORD=polymart
POSTGRES_DB=polymart
DATABASE_URL=postgres://polymart:polymart@db:5432/polymart

# --- Redis / Celery ---------------------------------------------------------
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# --- Observability (OpenTelemetry tracing; optional) ------------------------
OTEL_ENABLED=false
OTEL_SERVICE_NAME=polymart-backend
OTEL_EXPORTER_OTLP_ENDPOINT=

# --- Frontend ---------------------------------------------------------------
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
