# Template for backend/.env. Run `make env` to copy this with defaults.
# Native dev uses localhost; the Docker stack overrides the DB/Redis hosts.
# Never commit the real .env.

# --- Django -----------------------------------------------------------------
DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_SECRET_KEY=insecure-dev-key-change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_LOG_LEVEL=INFO
DJANGO_JSON_LOGS=false

# --- Database (native: localhost; Docker overrides host to "db") ------------
POSTGRES_USER=polymart
POSTGRES_PASSWORD=polymart
POSTGRES_DB=polymart
DATABASE_URL=postgres://polymart:polymart@localhost:5432/polymart

# --- Redis / Celery (native: localhost; Docker overrides host to "redis") ---
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# --- Observability (OpenTelemetry tracing; optional) ------------------------
OTEL_ENABLED=false
OTEL_SERVICE_NAME=polymart-backend
OTEL_EXPORTER_OTLP_ENDPOINT=

# --- Frontend ---------------------------------------------------------------
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
